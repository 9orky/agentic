{
  "language": "typescript",
  "exclusions": [
    "node_modules/",
    "__tests__/",
    ".test.ts",
    ".spec.ts",
    "dist/",
    ".arch-checker/",
    "agentic/"
  ],
  "rules": {
    "boundaries": [
      {
        "source": "src/features/subject",
        "disallow": [
          "src/features/constraint",
          "src/features/scoring",
          "src/features/scheduling",
          "src/features/tracing",
          "src/features/validation"
        ]
      },
      {
        "source": "src/features/constraint",
        "disallow": [
          "src/features/scoring",
          "src/features/scheduling",
          "src/features/tracing",
          "src/features/validation"
        ]
      },
      {
        "source": "src/features/scoring",
        "disallow": [
          "src/features/constraint",
          "src/features/scheduling",
          "src/features/tracing",
          "src/features/validation"
        ]
      },
      {
        "source": "src/features/tracing",
        "disallow": [
          "src/features/constraint",
          "src/features/scoring",
          "src/features/scheduling",
          "src/features/validation"
        ]
      },
      {
        "source": "src/features/validation",
        "disallow": [
          "src/features/constraint",
          "src/features/scoring",
          "src/features/scheduling",
          "src/features/tracing"
        ]
      },
      {
        "source": "src/features/scheduling",
        "disallow": ["src/features/validation"]
      }
    ]
  }
}
